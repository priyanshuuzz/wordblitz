    "firebase": "^11.9.1",
    "firebase-admin": "13.4.0",
    "helmet": "8.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.3",
