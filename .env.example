# ═══════════════════════════════════════════════════════════════════
#  WORDBLITZ — Environment Configuration Template
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── AI (OpenRouter) ──────────────────────────────────────────────────────────
# Powers the in-game AI word hints via OpenRouter → Gemini 2.0 Flash
# Get your key at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY="sk-or-v1-YOUR_KEY_HERE"

# ── Firebase Client (browser-safe, exposed via Vite VITE_* prefix) ───────────
# Source: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"

# ── Firebase Admin (server-side only — NEVER expose to client) ───────────────
# Paste the full service account JSON as a single line (no line breaks)
# Source: Firebase Console → Project Settings → Service Accounts → Generate new key
FIREBASE_SERVICE_ACCOUNT_JSON=''

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL="http://localhost:3000"

# Comma-separated list of allowed CORS origins in production
# ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"
